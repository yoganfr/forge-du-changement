# Copier vers .env (non versionné) pour le dev local.
# Voir docs/security-quick-wins.md pour MFA, audit et vérifs RLS.

# URL du projet Supabase (Settings → API)
VITE_SUPABASE_URL=

# Clé « anon » / publishable uniquement (Settings → API → Project API keys).
# Ne jamais mettre la service_role ici ni dans le bundle front.
VITE_SUPABASE_KEY=
